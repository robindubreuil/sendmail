# Sendmail Environment Configuration
# This file contains sensitive configuration and should have restricted permissions
# Copy this file and fill in your actual values

# Required - Google reCAPTCHA secret key
RECAPTCHA_SECRET_KEY=

# Required - SMTP configuration
SMTP_HOST=
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_ADDRESS=
TO_ADDRESS=

# Optional - Override reCAPTCHA verify URL
# RECAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify

# Optional - Override SMTP port
# SMTP_PORT=587